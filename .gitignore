## .NET / C# gitignore

# Build output
bin/
obj/
out/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.DotSettings.user

# dotnet publish output
publish/
artifacts/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets
.env
.env.local
appsettings.Local.json
appsettings.*.Local.json
secrets.json

# AWS
.aws-lambda-tools-*-temp/

# Test results
TestResults/
coverage/
*.coverage
*.coveragexml
